<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Runboat</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          crossorigin="anonymous">
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
          crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            crossorigin="anonymous"></script>
    <style>
        html, body { height: 100%; margin: 0; }
        body {
            display: flex;
            flex-direction: column;
            font-family: Arial, Helvetica, sans-serif;
            font-size: 0.9rem;
            background: #f8f9fa;
        }

        /* ── Navbar ── */
        #navbar {
            background: #2c3e50;
            padding: 0.5rem 1rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            flex-shrink: 0;
        }
        #navbar .brand {
            color: white;
            font-weight: bold;
            font-size: 1.05rem;
            text-decoration: none;
        }
        .status-pill {
            font-size: 0.78rem;
            padding: 0.2em 0.6em;
            border-radius: 1em;
            font-weight: 600;
        }
        .pill-running  { background: #27ae60; color: #fff; }
        .pill-failed   { background: #e74c3c; color: #fff; }
        .pill-stopped  { background: #6c757d; color: #fff; }
        .pill-pending  { background: #f39c12; color: #fff; }
        #search-box {
            margin-left: auto;
            width: 220px;
            font-size: 0.85rem;
        }

        /* ── Layout ── */
        #layout {
            display: flex;
            flex: 1;
            overflow: hidden;
        }

        /* ── Sidebar ── */
        #sidebar {
            width: 200px;
            flex-shrink: 0;
            background: #fff;
            border-right: 1px solid #dee2e6;
            overflow-y: auto;
            padding: 0.75rem 0;
        }
        .sidebar-heading {
            font-size: 0.68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #adb5bd;
            padding: 0.5rem 0.85rem 0.25rem;
        }
        .sidebar-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.32rem 0.85rem;
            text-decoration: none;
            color: #343a40;
            font-size: 0.85rem;
            cursor: pointer;
            border: none;
            background: none;
            width: 100%;
            text-align: left;
        }
        .sidebar-item:hover { background: #f1f3f5; }
        .sidebar-item.active { background: #e7f1ff; font-weight: 600; color: #0d6efd; }
        .sidebar-dot {
            width: 8px; height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
            margin-right: 0.4rem;
            background: #adb5bd;
        }
        .dot-ok      { background: #198754; }
        .dot-failed  { background: #dc3545; }
        .dot-pending { background: #fd7e14; }
        .dot-stopped { background: #adb5bd; }
        .sidebar-count {
            font-size: 0.72rem;
            background: #e9ecef;
            color: #6c757d;
            padding: 0.1em 0.45em;
            border-radius: 1em;
        }

        /* ── Main ── */
        #main {
            flex: 1;
            overflow-y: auto;
            padding: 1rem 1.25rem;
        }
        /* ── Branch sections ── */
        .branch-section { margin-bottom: 1.5rem; }
        .branch-section-title {
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #6c757d;
            border-bottom: 1px solid #dee2e6;
            padding-bottom: 0.3rem;
            margin-bottom: 0.75rem;
        }

        /* ── PR/branch row (horizontal strip of cards) ── */
        .pr-row { margin-bottom: 0.9rem; }
        .pr-row-label {
            display: flex;
            align-items: center;
            gap: 0.45rem;
            margin-bottom: 0.35rem;
            font-size: 0.75rem;
        }
        .pr-row-title {
            font-weight: 700;
            color: #343a40;
            text-decoration: none;
        }
        .pr-row-title:hover { text-decoration: underline; }
        .pr-row-headref {
            color: #0d6efd;
            font-size: 0.72rem;
            background: #e7f1ff;
            padding: 0.05em 0.4em;
            border-radius: 3px;
            max-width: 180px;
            overflow: hidden;
            white-space: nowrap;
            text-overflow: ellipsis;
        }
        .pr-row-cards {
            display: flex;
            flex-direction: row;
            flex-wrap: nowrap;
            gap: 0.5rem;
            overflow-x: auto;
            padding-bottom: 0.2rem;
        }

        /* ── Build card (Odoo runbot style) ── */
        .build-card {
            width: 220px;
            flex-shrink: 0;
            border-radius: 6px;
            border: 1px solid rgba(0,0,0,.08);
            overflow: visible;
            font-size: 0.82rem;
            display: flex;
            flex-direction: column;
        }
        .build-card-header {
            padding: 0.35rem 0.6rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 0.3rem;
            border-bottom: 1px solid rgba(0,0,0,.06);
        }
        .commit-hash {
            font-family: monospace;
            font-size: 0.8rem;
            font-weight: 600;
            color: #343a40;
            text-decoration: none;
        }
        .commit-hash:hover { text-decoration: underline; }
        .build-card-time {
            font-size: 0.72rem;
            color: #6c757d;
            margin-left: auto;
        }
        .build-card-body {
            padding: 0.5rem 0.6rem;
            flex: 1;
        }
        .build-slot {
            display: flex;
            flex-direction: column;
            gap: 0.3rem;
            padding: 0.2rem 0;
            border-bottom: 1px solid rgba(0,0,0,.04);
        }
        .build-slot:last-child { border-bottom: none; }
        .slot-main {
            display: flex;
            align-items: center;
            gap: 0.35rem;
        }
        .slot-icon {
            width: 16px;
            text-align: center;
            font-size: 0.8rem;
            flex-shrink: 0;
        }
        .slot-name {
            flex: 1;
            overflow: hidden;
            white-space: nowrap;
            text-overflow: ellipsis;
            color: #212529;
            font-size: 0.82rem;
            font-weight: 500;
        }
        .slot-name a { color: inherit; text-decoration: none; }
        .slot-name a:hover { text-decoration: underline; }
        .slot-sub {
            font-size: 0.7rem;
            color: #6c757d;
            padding-left: 22px;
            text-transform: capitalize;
        }
        .slot-actions {
            display: flex;
            justify-content: flex-end;
            gap: 2px;
            margin-top: 0.15rem;
        }
        .slot-btn {
            border: none;
            background: none;
            cursor: pointer;
            padding: 2px 5px;
            border-radius: 3px;
            font-size: 0.78rem;
            color: #6c757d;
        }
        .slot-btn:hover { background: rgba(0,0,0,.08); color: #343a40; }
        .slot-btn:disabled { opacity: 0.35; cursor: default; }
        .slot-btn.btn-open { color: #0d6efd; }
        .slot-btn.btn-stop { color: #dc3545; }
        .slot-btn.btn-start { color: #198754; }
        .slot-actions .dropdown-menu { font-size: 0.8rem; min-width: 160px; }
        .slot-actions .dropdown-item { padding: 0.25rem 0.75rem; }
        .slot-actions .dropdown-item i { width: 16px; margin-right: 0.4rem; color: #6c757d; }
        .slot-actions .dropdown-item.disabled i { color: #adb5bd; }

        /* Card background by worst status */
        .card-ok      { background: #d1e7dd; }  /* bg-success-subtle */
        .card-failed  { background: #f8d7da; }  /* bg-danger-subtle  */
        .card-pending { background: #cff4fc; }  /* bg-info-subtle    */
        .card-stopped { background: #f8f9fa; }  /* bg-light          */

        #footer {
            color: #6c757d;
            font-size: 0.75rem;
            padding: 0.4rem 1rem;
            border-top: 1px solid #dee2e6;
            background: #fff;
            flex-shrink: 0;
        }
    </style>
</head>
<body>

<!-- ── Navbar ── -->
<div id="navbar">
    <a href="/" class="brand">🚢 Runboat</a>
    <span class="status-pill pill-running" id="pill-running">⬤ 0</span>
    <span class="status-pill pill-pending" id="pill-pending" style="display:none">⧖ 0</span>
    <span class="status-pill pill-failed"  id="pill-failed"  style="display:none">✗ 0</span>
    <span class="status-pill pill-stopped" id="pill-stopped">○ 0</span>
    <input id="search-box" class="form-control form-control-sm"
           type="search" placeholder="🔍 buscar rama o PR…">
</div>

<!-- ── Layout ── -->
<div id="layout">

    <!-- Sidebar -->
    <nav id="sidebar">
        <div class="sidebar-heading">Repositorios</div>
        <div id="repo-list"></div>

        <div class="sidebar-heading" style="margin-top:0.5rem">Ramas</div>
        <div id="branch-list"></div>
    </nav>

    <!-- Main -->
    <div id="main">
        <div id="connecting" class="text-muted p-3">Conectando…</div>
        <div id="builds"></div>
    </div>
</div>

<div id="footer">
    {{ footer_html }}
    {{ additional_footer_html }}
</div>

<script>
// ── Estado global ─────────────────────────────────────────────────────────────
const builds     = {};       // name → build
const prCache    = {};       // "repo#pr" → {head_ref, title} | "loading" | "error"
let configuredRepos = [];    // all repos from RUNBOAT_REPOS config
let activeBranch = null;     // null = todas
let activeRepo   = null;     // null = todos los repos
let searchTerm   = '';

// ── Utilidades ────────────────────────────────────────────────────────────────

function timeAgo(isoStr) {
    const diff = Math.floor((Date.now() - new Date(isoStr)) / 1000);
    if (diff < 60)   return `${diff}s ago`;
    if (diff < 3600) return `${Math.floor(diff/60)}m ago`;
    if (diff < 86400) return `${Math.floor(diff/3600)}h ago`;
    return `${Math.floor(diff/86400)}d ago`;
}

function repoShort(fullRepo) {
    // "bmya/odoo-bmya" → "odoo-bmya"
    return fullRepo.split('/')[1] || fullRepo;
}

function branchSortKey(name) {
    if (name === 'master') return '00000';
    const m = name.match(/^(\d+)\.(\d+)/);
    if (m) return String(100000 - parseInt(m[1]) * 100 - parseInt(m[2])).padStart(6,'0');
    return 'z' + name;
}

// ── Status helpers ────────────────────────────────────────────────────────────
const PENDING_STATUSES = new Set(['initializing','starting','stopping','to_initialize']);

function worstStatus(buildList) {
    if (buildList.some(b => b.test_status === 'failed'))            return 'failed';
    if (buildList.some(b => b.status === 'failed'))                 return 'failed';
    if (buildList.some(b => b.test_status === 'running'))           return 'pending';
    if (buildList.some(b => PENDING_STATUSES.has(b.status)))        return 'pending';
    if (buildList.some(b => b.status === 'started'))                return 'ok';
    return 'stopped';
}

function cardClass(ws) {
    return {failed:'card-failed', pending:'card-pending', ok:'card-ok', stopped:'card-stopped'}[ws];
}

function dotClass(ws) {
    return {failed:'dot-failed', pending:'dot-pending', ok:'dot-ok', stopped:'dot-stopped'}[ws];
}

function statusIcon(s) {
    const icons = {
        started:      '<i class="fa fa-circle text-success"></i>',
        failed:       '<i class="fa fa-circle text-danger"></i>',
        stopped:      '<i class="fa fa-circle text-secondary"></i>',
        initializing: '<i class="fa fa-spinner fa-spin text-info"></i>',
        starting:     '<i class="fa fa-spinner fa-spin text-success"></i>',
        stopping:     '<i class="fa fa-spinner fa-spin text-secondary"></i>',
    };
    return icons[s] || '<i class="fa fa-circle-o text-muted"></i>';
}

// ── PR info cache ─────────────────────────────────────────────────────────────
async function fetchPrInfo(repo, pr) {
    const key = `${repo}#${pr}`;
    if (prCache[key] && prCache[key] !== 'loading') return prCache[key];
    if (prCache[key] === 'loading') return null;
    prCache[key] = 'loading';
    try {
        const r = await fetch(`/api/v1/pr-info?repo=${encodeURIComponent(repo)}&pr=${pr}`);
        prCache[key] = r.ok ? await r.json() : { head_ref: '', title: '' };
    } catch(e) {
        prCache[key] = { head_ref: '', title: '' };
    }
    return prCache[key];
}

// Warm up cache for all PR builds lazily
function warmPrCache() {
    for (const b of Object.values(builds)) {
        if (b.commit_info.pr) {
            const key = `${b.commit_info.repo}#${b.commit_info.pr}`;
            if (!prCache[key]) fetchPrInfo(b.commit_info.repo, b.commit_info.pr);
        }
    }
}

// ── Build data structure (two-level: rows → cards) ───────────────────────────
function buildStructure() {
    // rows: rowKey → {target_branch, pr, repo, latestCreated, cardKeys: Set}
    // cards: cardKey → {target_branch, pr, repo, git_commit, builds: [], created}
    const rows = {};
    const cardMap = {};
    const allRepos = new Set();

    for (const b of Object.values(builds)) {
        const { repo, target_branch, pr, git_commit } = b.commit_info;
        allRepos.add(repo);

        // Row key: one row per PR (across repos) or per repo+branch
        const rowKey = pr
            ? `${target_branch}::pr${pr}`
            : `${repo}::${target_branch}`;
        // Card key: one card per commit
        const cardKey = pr
            ? `${target_branch}::pr${pr}::${git_commit}`
            : `${repo}::${target_branch}::${git_commit}`;

        if (!rows[rowKey]) {
            rows[rowKey] = { target_branch, pr, repo, latestCreated: '', cardKeys: new Set() };
        }
        rows[rowKey].cardKeys.add(cardKey);

        if (!cardMap[cardKey]) {
            cardMap[cardKey] = { target_branch, pr, repo, git_commit, builds: [], created: b.created };
        }
        cardMap[cardKey].builds.push(b);
        if (b.created > cardMap[cardKey].created) cardMap[cardKey].created = b.created;
    }

    // Compute latestCreated for each row (most recent card)
    for (const row of Object.values(rows)) {
        row.latestCreated = [...row.cardKeys]
            .map(ck => cardMap[ck].created)
            .sort().at(-1) || '';
    }

    return { rows, cardMap, allRepos };
}

// ── Row filter ────────────────────────────────────────────────────────────────
function rowMatches(row, cardMap) {
    // Repo filter
    if (activeRepo) {
        const hasRepo = [...row.cardKeys].some(ck =>
            cardMap[ck].builds.some(b => b.commit_info.repo === activeRepo)
        );
        if (!hasRepo) return false;
    }
    // Search filter
    if (searchTerm) {
        const term = searchTerm.toLowerCase();
        if (row.target_branch.toLowerCase().includes(term)) return true;
        if (row.pr && String(row.pr).includes(term)) return true;
        if (row.pr) {
            for (const ck of row.cardKeys) {
                for (const b of cardMap[ck].builds) {
                    const info = prCache[`${b.commit_info.repo}#${row.pr}`];
                    if (info && info !== 'loading') {
                        if (info.head_ref.toLowerCase().includes(term)) return true;
                        if (info.title.toLowerCase().includes(term)) return true;
                    }
                }
            }
        }
        return false;
    }
    return true;
}

// ── Render ────────────────────────────────────────────────────────────────────
function render() {
    const { rows, cardMap, allRepos } = buildStructure();

    // Group rows by branch
    const byBranch = {};
    for (const [rowKey, row] of Object.entries(rows)) {
        const br = row.target_branch;
        if (!byBranch[br]) byBranch[br] = [];
        byBranch[br].push(row);
    }

    const branches = Object.keys(byBranch).sort((a,b) =>
        branchSortKey(a).localeCompare(branchSortKey(b))
    );

    // ── Sidebar: repos ──
    const repoList = document.getElementById('repo-list');
    repoList.innerHTML = '';
    const allRepoNames = new Set([...configuredRepos, ...allRepos]);
    for (const repo of [...allRepoNames].sort()) {
        const item = document.createElement('div');
        item.style.cssText = 'display:flex;align-items:center';
        const btn = document.createElement('button');
        btn.className = 'sidebar-item' + (activeRepo === repo ? ' active' : '');
        btn.style.flex = '1';
        btn.textContent = repoShort(repo);
        btn.addEventListener('click', () => {
            activeRepo = (activeRepo === repo) ? null : repo;
            render();
        });
        const ghLink = document.createElement('a');
        ghLink.href = `https://github.com/${repo}`;
        ghLink.target = '_blank';
        ghLink.title = 'Ver en GitHub';
        ghLink.style.cssText = 'padding:0.32rem 0.5rem 0.32rem 0;color:#adb5bd;font-size:0.72rem';
        ghLink.innerHTML = '<i class="fa fa-external-link"></i>';
        item.appendChild(btn);
        item.appendChild(ghLink);
        repoList.appendChild(item);
    }

    // ── Sidebar: branches ──
    const branchList = document.getElementById('branch-list');
    branchList.innerHTML = '';
    for (const br of branches) {
        const allBranchBuilds = byBranch[br]
            .flatMap(row => [...row.cardKeys].flatMap(ck => cardMap[ck].builds));
        const ws = worstStatus(allBranchBuilds);
        const count = allBranchBuilds.length;
        const btn = document.createElement('button');
        btn.className = 'sidebar-item' + (activeBranch === br ? ' active' : '');
        btn.innerHTML =
            `<span><span class="sidebar-dot ${dotClass(ws)}"></span>${br}</span>`
            + `<span class="sidebar-count">${count}</span>`;
        btn.addEventListener('click', () => {
            activeBranch = (activeBranch === br) ? null : br;
            render();
        });
        branchList.appendChild(btn);
    }

    // ── Main: branch sections ──
    const buildsDiv = document.getElementById('builds');
    buildsDiv.innerHTML = '';

    const visibleBranches = activeBranch ? [activeBranch] : branches;

    for (const br of visibleBranches) {
        if (!byBranch[br]) continue;

        // Filter and sort rows: newest activity first (top row = most recent push)
        const visibleRows = byBranch[br]
            .filter(row => rowMatches(row, cardMap))
            .sort((a, b) => b.latestCreated.localeCompare(a.latestCreated));

        if (visibleRows.length === 0) continue;

        const section = document.createElement('div');
        section.className = 'branch-section';
        section.innerHTML = `<div class="branch-section-title">${br}</div>`;

        for (const row of visibleRows) {
            section.appendChild(buildPrRow(row, cardMap));
        }

        buildsDiv.appendChild(section);
    }

    initDropdowns();
}

// Re-init Bootstrap dropdowns after each render (DOM is regenerated).
// Using popper strategy:'fixed' so dropdown escapes the overflow-x:auto on .pr-row-cards.
function initDropdowns() {
    if (typeof bootstrap === 'undefined') return;
    document.querySelectorAll('.slot-actions [data-bs-toggle="dropdown"]').forEach(el => {
        new bootstrap.Dropdown(el, {
            popperConfig: (cfg) => ({ ...cfg, strategy: 'fixed' }),
        });
    });
}

// ── Build a PR/branch row (horizontal strip of cards) ─────────────────────────
function buildPrRow(row, cardMap) {
    const rowEl = document.createElement('div');
    rowEl.className = 'pr-row';

    // Row label: PR link + head_ref (if PR)
    const prKey = row.pr ? `${row.repo}#${row.pr}` : null;
    const prInfo = prKey && prCache[prKey] && prCache[prKey] !== 'loading' ? prCache[prKey] : null;
    const headRef = prInfo ? prInfo.head_ref : '';

    const titleLink = row.pr
        ? `https://github.com/${row.repo}/pull/${row.pr}`
        : `https://github.com/${row.repo}/tree/${row.target_branch}`;
    const titleText = row.pr ? `PR #${row.pr}` : repoShort(row.repo);

    rowEl.innerHTML = `
        <div class="pr-row-label">
            <a href="${titleLink}" target="_blank" class="pr-row-title">${titleText}</a>
            ${headRef ? `<span class="pr-row-headref" title="${headRef}">${headRef}</span>` : ''}
        </div>
        <div class="pr-row-cards"></div>
    `;

    // Sort cards newest (left) → oldest (right)
    const sortedCards = [...row.cardKeys]
        .map(ck => cardMap[ck])
        .sort((a, b) => b.created.localeCompare(a.created));

    const cardsEl = rowEl.querySelector('.pr-row-cards');
    for (const card of sortedCards) {
        cardsEl.appendChild(buildCard(card));
    }

    return rowEl;
}

function buildCard(card) {
    const ws = worstStatus(card.builds);
    const el = document.createElement('div');
    el.className = `build-card ${cardClass(ws)}`;

    const ago = timeAgo(card.created);
    const commitShort = card.git_commit.slice(0, 7);
    // First build has repo_commit_link for this commit
    const commitLink = card.builds[0]?.repo_commit_link || '#';

    el.innerHTML = `
        <div class="build-card-header">
            <a href="${commitLink}" target="_blank" class="commit-hash">${commitShort}</a>
            <span class="build-card-time">${ago}</span>
        </div>
        <div class="build-card-body"></div>
    `;

    const body = el.querySelector('.build-card-body');
    for (const b of card.builds) {
        body.appendChild(buildSlot(b));
    }

    return el;
}

function buildSlot(b) {
    const slot = document.createElement('div');
    slot.className = 'build-slot';
    slot.dataset.name = b.name;

    const isStarted = b.status === 'started';
    const isStopped = b.status === 'stopped';
    const isFailed  = b.status === 'failed';

    slot.innerHTML = `
        <div class="slot-main">
            <span class="slot-icon">${statusIcon(b.status)}</span>
            <span class="slot-name">
                <a href="${b.webui_link}" title="${b.commit_info.repo}">${repoShort(b.commit_info.repo)}</a>
            </span>
        </div>
        <div class="slot-sub">${b.status.replace('_', ' ')}</div>
        <div class="slot-actions">
            <button class="slot-btn btn-open" title="Abrir Odoo"
                    ${!isStarted ? 'disabled' : ''}
                    onclick="window.open('${b.deploy_link}','_blank')">
                <i class="fa fa-sign-in"></i>
            </button>
            <button class="slot-btn btn-start" title="Iniciar"
                    ${(!isStopped && !isFailed) ? 'disabled' : ''}
                    onclick="buildAction('${b.name}','start',this)">
                <i class="fa fa-play"></i>
            </button>
            <button class="slot-btn btn-stop" title="Detener"
                    ${!isStarted ? 'disabled' : ''}
                    onclick="buildAction('${b.name}','stop',this)">
                <i class="fa fa-stop"></i>
            </button>
            <button class="slot-btn" title="Reiniciar"
                    onclick="buildAction('${b.name}','reset',this)">
                <i class="fa fa-refresh"></i>
            </button>
            <div class="dropdown d-inline-block">
                <button class="slot-btn" data-bs-toggle="dropdown" aria-expanded="false" title="Más acciones">
                    <i class="fa fa-cog"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" target="_blank"
                           href="/webui/log-viewer.html?name=${encodeURIComponent(b.name)}&kind=init">
                        <i class="fa fa-list-alt"></i>Init log
                    </a></li>
                    <li><a class="dropdown-item ${!isStarted ? 'disabled' : ''}"
                           target="_blank"
                           href="${isStarted ? `/webui/log-viewer.html?name=${encodeURIComponent(b.name)}&kind=runtime` : '#'}"
                           ${!isStarted ? 'tabindex="-1" aria-disabled="true"' : ''}>
                        <i class="fa fa-file-text-o"></i>Log
                    </a></li>
                    ${b.test_status ? `
                    <li><a class="dropdown-item" target="_blank"
                           href="/webui/log-viewer.html?name=${encodeURIComponent(b.name)}&kind=test">
                        <i class="fa fa-flask"></i>Test log (${b.test_status})
                    </a></li>` : ''}
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item ${!isStarted ? 'disabled' : ''}"
                           target="_blank"
                           href="${isStarted ? b.deploy_link_mailhog : '#'}"
                           ${!isStarted ? 'tabindex="-1" aria-disabled="true"' : ''}>
                        <i class="fa fa-envelope-o"></i>Mailhog
                    </a></li>
                </ul>
            </div>
        </div>
    `;
    return slot;
}

async function buildAction(name, action, btn) {
    btn.disabled = true;
    try {
        await fetch(`/api/v1/builds/${name}/${action}`, {method: 'POST'});
    } catch(e) {}
}

// ── Status header ─────────────────────────────────────────────────────────────
async function refreshStatus() {
    try {
        const r = await fetch('/api/v1/status');
        if (!r.ok) return;
        const s = await r.json();
        const running = (s.started || 0);
        const pending = (s.initializing || 0) + (s.to_initialize || 0);
        const failed  = s.failed  || 0;
        const stopped = s.stopped || 0;
        document.getElementById('pill-running').textContent = `⬤ ${running}`;
        document.getElementById('pill-pending').textContent = `⧖ ${pending}`;
        document.getElementById('pill-failed').textContent  = `✗ ${failed}`;
        document.getElementById('pill-stopped').textContent = `○ ${stopped}`;
        document.getElementById('pill-pending').style.display = pending > 0 ? '' : 'none';
        document.getElementById('pill-failed').style.display  = failed  > 0 ? '' : 'none';
    } catch(e) {}
}

// ── Search ────────────────────────────────────────────────────────────────────
let searchDebounce = null;
document.getElementById('search-box').addEventListener('input', e => {
    clearTimeout(searchDebounce);
    searchDebounce = setTimeout(() => {
        searchTerm = e.target.value.trim();
        render();
    }, 200);
});

// ── SSE ───────────────────────────────────────────────────────────────────────
let evtSource = null;

function onopen() {
    document.getElementById('connecting').style.display = 'none';
    refreshStatus();
}

function onmessage(event) {
    const ev = JSON.parse(event.data);
    if (ev.event === 'upd') {
        builds[ev.build.name] = ev.build;
    } else if (ev.event === 'del') {
        delete builds[ev.build.name];
    }
    warmPrCache();
    render();
    refreshStatus();
}

function onerror() {
    evtSource.close();
    setTimeout(connect, 10000);
}

function connect() {
    evtSource = new EventSource('/api/v1/build-events');
    evtSource.onopen    = onopen;
    evtSource.onmessage = onmessage;
    evtSource.onerror   = onerror;
}

// Fetch all configured repos once on load
async function fetchConfiguredRepos() {
    try {
        const r = await fetch('/api/v1/configured-repos');
        if (r.ok) {
            configuredRepos = await r.json();
            render();
        }
    } catch(e) {}
}

connect();
fetchConfiguredRepos();

// Refresh PR branch names every 30s to pick up newly cached info
setInterval(() => { warmPrCache(); render(); }, 30000);
</script>
</body>
</html>
