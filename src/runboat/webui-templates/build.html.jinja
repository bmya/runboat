<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Runboat build</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          crossorigin="anonymous">
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
          crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            crossorigin="anonymous"></script>
    <style>
        html, body { height: 100%; margin: 0; }
        body {
            display: flex;
            flex-direction: column;
            font-family: Arial, Helvetica, sans-serif;
            font-size: 0.9rem;
            background: #f8f9fa;
        }
        #navbar {
            background: #2c3e50;
            padding: 0.5rem 1rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            flex-shrink: 0;
        }
        #navbar .brand { color: white; font-weight: bold; font-size: 1.05rem; text-decoration: none; }
        #main { flex: 1; padding: 1.25rem; overflow-y: auto; }

        /* ── Build card (match index) ── */
        .build-card {
            width: 260px;
            border-radius: 6px;
            border: 1px solid rgba(0,0,0,.08);
            overflow: visible;
            font-size: 0.82rem;
            display: flex;
            flex-direction: column;
        }
        .build-card-header {
            padding: 0.4rem 0.7rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 0.3rem;
            border-bottom: 1px solid rgba(0,0,0,.06);
        }
        .commit-hash {
            font-family: monospace;
            font-size: 0.82rem;
            font-weight: 600;
            color: #343a40;
            text-decoration: none;
        }
        .commit-hash:hover { text-decoration: underline; }
        .build-card-time { font-size: 0.72rem; color: #6c757d; margin-left: auto; }
        .build-card-body { padding: 0.55rem 0.7rem; }

        .build-slot {
            display: flex;
            flex-direction: column;
            gap: 0.3rem;
            padding: 0.2rem 0;
        }
        .slot-main { display: flex; align-items: center; gap: 0.35rem; }
        .slot-icon { width: 16px; text-align: center; font-size: 0.8rem; flex-shrink: 0; }
        .slot-name {
            flex: 1; overflow: hidden; white-space: nowrap;
            text-overflow: ellipsis; color: #212529; font-size: 0.82rem; font-weight: 500;
        }
        .slot-name a { color: inherit; text-decoration: none; }
        .slot-name a:hover { text-decoration: underline; }
        .slot-sub {
            font-size: 0.7rem; color: #6c757d;
            padding-left: 22px; text-transform: capitalize;
        }
        .slot-actions {
            display: flex; justify-content: flex-end;
            gap: 2px; margin-top: 0.15rem;
        }
        .slot-btn {
            border: none; background: none; cursor: pointer;
            padding: 2px 5px; border-radius: 3px;
            font-size: 0.78rem; color: #6c757d;
        }
        .slot-btn:hover { background: rgba(0,0,0,.08); color: #343a40; }
        .slot-btn:disabled { opacity: 0.35; cursor: default; }
        .slot-btn.btn-open { color: #0d6efd; }
        .slot-btn.btn-stop { color: #dc3545; }
        .slot-btn.btn-start { color: #198754; }
        .slot-actions .dropdown-menu { font-size: 0.8rem; min-width: 160px; }
        .slot-actions .dropdown-item { padding: 0.25rem 0.75rem; }
        .slot-actions .dropdown-item i { width: 16px; margin-right: 0.4rem; color: #6c757d; }
        .slot-actions .dropdown-item.disabled i { color: #adb5bd; }

        .card-ok      { background: #d1e7dd; }
        .card-failed  { background: #f8d7da; }
        .card-pending { background: #cff4fc; }
        .card-stopped { background: #f8f9fa; }

        #footer {
            color: #6c757d; font-size: 0.75rem;
            padding: 0.4rem 1rem; border-top: 1px solid #dee2e6;
            background: #fff; flex-shrink: 0;
        }
    </style>
</head>
<body>

<div id="navbar">
    <a href="/" class="brand">🚢 Runboat</a>
</div>

<div id="main">
    <div class="mb-3">
        <a href="/" class="text-muted text-decoration-none" style="font-size:0.85rem">
            <i class="fa fa-arrow-left"></i> Volver al inicio
        </a>
    </div>
    <div id="build-info" class="mb-3" style="font-size:0.85rem;color:#6c757d">Conectando…</div>
    <div id="build-card-container"></div>
    <div id="repolink" class="mt-3" style="font-size:0.82rem;color:#6c757d"></div>
</div>

<div id="footer">
    {{ footer_html }}
    {{ additional_footer_html }}
</div>

<script>
const PENDING_STATUSES = new Set(['initializing','starting','stopping','to_initialize']);

function timeAgo(isoStr) {
    const diff = Math.floor((Date.now() - new Date(isoStr)) / 1000);
    if (diff < 60)   return `${diff}s ago`;
    if (diff < 3600) return `${Math.floor(diff/60)}m ago`;
    if (diff < 86400) return `${Math.floor(diff/3600)}h ago`;
    return `${Math.floor(diff/86400)}d ago`;
}

function worstStatus(builds) {
    if (builds.some(b => b.status === 'failed')) return 'failed';
    if (builds.some(b => PENDING_STATUSES.has(b.status))) return 'pending';
    if (builds.some(b => b.status === 'started')) return 'ok';
    return 'stopped';
}

function cardClass(ws) {
    return {failed:'card-failed', pending:'card-pending', ok:'card-ok', stopped:'card-stopped'}[ws];
}

function statusIcon(s) {
    const icons = {
        started:      '<i class="fa fa-circle text-success"></i>',
        failed:       '<i class="fa fa-circle text-danger"></i>',
        stopped:      '<i class="fa fa-circle text-secondary"></i>',
        initializing: '<i class="fa fa-spinner fa-spin text-info"></i>',
        starting:     '<i class="fa fa-spinner fa-spin text-success"></i>',
        stopping:     '<i class="fa fa-spinner fa-spin text-secondary"></i>',
    };
    return icons[s] || '<i class="fa fa-circle text-muted"></i>';
}

function repoShort(fullRepo) {
    return fullRepo.split('/')[1] || fullRepo;
}

async function buildAction(name, action, btn) {
    btn.disabled = true;
    try { await fetch(`/api/v1/builds/${name}/${action}`, {method: 'POST'}); } catch(e) {}
}

function initDropdowns() {
    if (typeof bootstrap === 'undefined') return;
    document.querySelectorAll('.slot-actions [data-bs-toggle="dropdown"]').forEach(el => {
        new bootstrap.Dropdown(el);
    });
}

function renderBuild(b) {
    const ws = worstStatus([b]);
    const commitShort = b.commit_info.git_commit.slice(0, 7);
    const ago = timeAgo(b.created);

    const isStarted = b.status === 'started';
    const isStopped = b.status === 'stopped';
    const isFailed  = b.status === 'failed';

    const prText = b.commit_info.pr
        ? `<a href="${b.repo_pr_link}" target="_blank">PR #${b.commit_info.pr}</a> · `
        : '';
    document.getElementById('build-info').innerHTML =
        `${prText}<a href="${b.repo_target_branch_link}" target="_blank">${b.commit_info.repo} ${b.commit_info.target_branch}</a>`;

    const container = document.getElementById('build-card-container');
    container.innerHTML = `
        <div class="build-card ${cardClass(ws)}">
            <div class="build-card-header">
                <a href="${b.repo_commit_link}" target="_blank" class="commit-hash">${commitShort}</a>
                <span class="build-card-time">${ago}</span>
            </div>
            <div class="build-card-body">
                <div class="build-slot">
                    <div class="slot-main">
                        <span class="slot-icon">${statusIcon(b.status)}</span>
                        <span class="slot-name">
                            <a href="${b.webui_link}" title="${b.commit_info.repo}">${repoShort(b.commit_info.repo)}</a>
                        </span>
                    </div>
                    <div class="slot-sub">${b.status.replace('_', ' ')}</div>
                    <div class="slot-actions">
                        <button class="slot-btn btn-open" title="Abrir Odoo"
                                ${!isStarted ? 'disabled' : ''}
                                onclick="window.open('${b.deploy_link}','_blank')">
                            <i class="fa fa-sign-in"></i>
                        </button>
                        <button class="slot-btn btn-start" title="Iniciar"
                                ${(!isStopped && !isFailed) ? 'disabled' : ''}
                                onclick="buildAction('${b.name}','start',this)">
                            <i class="fa fa-play"></i>
                        </button>
                        <button class="slot-btn btn-stop" title="Detener"
                                ${!isStarted ? 'disabled' : ''}
                                onclick="buildAction('${b.name}','stop',this)">
                            <i class="fa fa-stop"></i>
                        </button>
                        <button class="slot-btn" title="Reiniciar"
                                onclick="buildAction('${b.name}','reset',this)">
                            <i class="fa fa-refresh"></i>
                        </button>
                        <div class="dropdown d-inline-block">
                            <button class="slot-btn" data-bs-toggle="dropdown" aria-expanded="false" title="Más acciones">
                                <i class="fa fa-cog"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" target="_blank"
                                       href="/api/v1/builds/${b.name}/init-log">
                                    <i class="fa fa-list-alt"></i>Init log
                                </a></li>
                                <li><a class="dropdown-item ${!isStarted ? 'disabled' : ''}"
                                       target="_blank"
                                       href="${isStarted ? `/api/v1/builds/${b.name}/log` : '#'}"
                                       ${!isStarted ? 'tabindex="-1" aria-disabled="true"' : ''}>
                                    <i class="fa fa-file-text-o"></i>Log
                                </a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item ${!isStarted ? 'disabled' : ''}"
                                       target="_blank"
                                       href="${isStarted ? b.deploy_link_mailhog : '#'}"
                                       ${!isStarted ? 'tabindex="-1" aria-disabled="true"' : ''}>
                                    <i class="fa fa-envelope-o"></i>Mailhog
                                </a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    `;

    document.getElementById('repolink').innerHTML =
        `Otros builds de <a href="/?repo=${b.commit_info.repo}">${b.commit_info.repo}</a>.`;

    initDropdowns();
}

// ── SSE ───────────────────────────────────────────────────────────────────────
let evtSource = null;

function onmessage(event) {
    const ev = JSON.parse(event.data);
    if (ev.event === 'upd') {
        renderBuild(ev.build);
    } else if (ev.event === 'del') {
        document.getElementById('build-info').textContent = 'Build eliminado.';
        document.getElementById('build-card-container').innerHTML = '';
    }
}

function onerror() {
    evtSource.close();
    setTimeout(connect, 10000);
}

function connect() {
    const buildName = new URLSearchParams(window.location.search).get('name');
    if (!buildName) {
        document.getElementById('build-info').textContent = 'No se especificó nombre de build.';
        return;
    }
    evtSource = new EventSource(`/api/v1/build-events?build_name=${buildName}`);
    evtSource.onmessage = onmessage;
    evtSource.onerror = onerror;
}

connect();
</script>
</body>
</html>
